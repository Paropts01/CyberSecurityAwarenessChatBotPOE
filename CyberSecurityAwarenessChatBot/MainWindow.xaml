<Window x:Class="CyberSecurityAwarenessChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSecurityAwarenessChatBot"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <!-- Add this Resources section with the button style -->
    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Lavender" />
            <Setter Property="Foreground" Value="DarkSlateBlue" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Optional: hover effect to make it more interactive -->
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A6A7A" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/pexels-codioful-7134987.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <!--Textbox for the ascii art logo-->
        <Border BorderBrush="Transparent"
                BorderThickness="3"
                CornerRadius="15"
                Padding="10"
                Background="Transparent"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="54,-5,0,0" Height="151" Width="237">
            <StackPanel>
                <!-- ASCII ART -->
                <TextBlock FontFamily="Consolas"
                           FontSize="9"
                           FontWeight="Bold"
                           Foreground="DarkSlateBlue"
                           TextWrapping="NoWrap"
                           HorizontalAlignment="Center" Width="279" Height="111">
                    <Run Text="                  _(,__           __),&#10;"/>
                    <Run Text="             (_,d888888888b,d888888888b&#10;"/>
                    <Run Text="              d888888888888/888888888888b_)&#10;"/>
                    <Run Text="           (_8888888P'&quot;&quot;&quot;'`Y8Y`'&quot;'&quot;&quot;Y88888&#10;"/>
                    <Run Text="             Y8888P.-'     `      '-.Y8888b_)&#10;"/>
                    <Run Text="            ,_Y88P (_(_(        )_)_) d88Y_,&#10;"/>
                    <Run Text="             Y88b,  ( o )      ( o ) d8888P&#10;"/>
                    <Run Text="             `Y888   '-'        '-'  `88Y`&#10;"/>
                    <Run Text="             ,d/O\         c         /O\b,&#10;"/>
                    <Run Text="               \_/'.,______w______,.'\_/"/>
                </TextBlock>
                <TextBlock Text="CyberSecurity Awareness Chatbot"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="DarkSlateBlue"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15" Height="24"/>
            </StackPanel>
        </Border>

        <!-- CHAT DISPLAY -->
        <Border CornerRadius="15"
        BorderThickness="0"
        Margin="54,151,53,90">

            <Border.Background>
                <SolidColorBrush Color="DarkSlateBlue"
                         Opacity="0.20"/>
            </Border.Background>

            <RichTextBox Name="ChatDisplay"
                 BorderThickness="0"
                 Background="Transparent"
                 Foreground="Black"
                 FontSize="14"
                 Padding="15"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 TextChanged="ChatDisplay_TextChanged_1" HorizontalAlignment="Center" Width="693"/>

        </Border>

        <!-- USER INPUT -->
        <Border CornerRadius="15"
        Height="42"
        Margin="54,0,120,20"
        VerticalAlignment="Bottom"
        BorderThickness="0">

            <Border.Background>
                <SolidColorBrush Color="DarkSlateBlue"
                         Opacity="0.25"/>
            </Border.Background>

            <TextBox Name="UserInput"
             BorderThickness="0"
             Background="Transparent"
             Foreground="Black"
             FontSize="14"
             VerticalContentAlignment="Center"
             Padding="15,0"
             KeyDown="UserInput_KeyDown">

                <TextBox.Resources>
                    <Style TargetType="TextBox">
                        <Setter Property="FocusVisualStyle"
                        Value="{x:Null}"/>
                    </Style>
                </TextBox.Resources>

            </TextBox>

        </Border>
        <!-- Apply the style to all buttons -->
        <Button Content="Send"
                Width="69"
                HorizontalAlignment="Right"
                Margin="0,0,44,20"
                VerticalAlignment="Bottom"
                Style="{StaticResource RoundedButtonStyle}"
                Click="SendButton_Click"/>

        <Button Content="Quiz Game"
                Width="91"
                HorizontalAlignment="Right"
                Margin="0,0,367,326"
                VerticalAlignment="Bottom"
                Style="{StaticResource RoundedButtonStyle}"
                Click="btnQuiz_Click"/>

        <Button Content="Tasks"
                Width="85"
                HorizontalAlignment="Right"
                Margin="0,0,262,324"
                VerticalAlignment="Bottom"
                Style="{StaticResource RoundedButtonStyle}"
                Click="btnTasks_Click"/>

        <Button Content="Log"
                Width="82"
                HorizontalAlignment="Right"
                Margin="0,0,156,324"
                VerticalAlignment="Bottom"
                Style="{StaticResource RoundedButtonStyle}"
                Click="btnLog_Click"/>

        <Button Content="Help"
                Width="84"
                HorizontalAlignment="Right"
                Margin="0,0,53,324"
                VerticalAlignment="Bottom"
                Style="{StaticResource RoundedButtonStyle}"
                Click="btnHelp_Click"/>
    </Grid>
</Window>
