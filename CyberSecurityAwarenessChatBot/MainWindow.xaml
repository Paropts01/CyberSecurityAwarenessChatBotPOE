<Window x:Class="CyberSecurityAwarenessChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSecurityAwarenessChatBot"
        mc:Ignorable="d"
        Title="CyberSecurity ChatBot"
        Height="600" Width="900"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Lavender" />
            <Setter Property="Foreground" Value="DarkSlateBlue" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A6A7A" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/pexels-codioful-7134987.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <!-- Define rows and columns to match original placement -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>      <!-- ASCII + title -->
            <RowDefinition Height="*"/>         <!-- Chat display -->
            <RowDefinition Height="Auto"/>      <!-- Input + Send -->
            <RowDefinition Height="Auto"/>      <!-- Action buttons -->
        </Grid.RowDefinitions>

        <!-- 1. ASCII art + title (top‑left) -->
        <Border Grid.Row="0"
                Margin="20,5,0,0"
                Background="Transparent"
                HorizontalAlignment="Left"
                VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal">
                <!-- Viewbox makes ASCII scale with window -->
                <Viewbox Width="220" Height="110" Margin="0,0,10,0">
                    <TextBlock FontFamily="Consolas"
                               FontSize="9"
                               FontWeight="Bold"
                               Foreground="DarkSlateBlue"
                               TextWrapping="NoWrap">
                        <Run Text="                  _(,__           __),&#10;"/>
                        <Run Text="             (_,d888888888b,d888888888b&#10;"/>
                        <Run Text="              d888888888888/888888888888b_)&#10;"/>
                        <Run Text="           (_8888888P'&quot;&quot;&quot;'`Y8Y`'&quot;'&quot;&quot;Y88888&#10;"/>
                        <Run Text="             Y8888P.-'     `      '-.Y8888b_)&#10;"/>
                        <Run Text="            ,_Y88P (_(_(        )_)_) d88Y_,&#10;"/>
                        <Run Text="             Y88b,  ( o )      ( o ) d8888P&#10;"/>
                        <Run Text="             `Y888   '-'        '-'  `88Y`&#10;"/>
                        <Run Text="             ,d/O\         c         /O\b,&#10;"/>
                        <Run Text="               \_/'.,______w______,.'\_/"/>
                    </TextBlock>
                </Viewbox>
                <TextBlock Text="CyberSecurity Awareness Chatbot"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="DarkSlateBlue"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 2. Chat display (fills remaining space) -->
        <Border Grid.Row="1"
                CornerRadius="15"
                Margin="30,10,30,10"
                Background="#40483D8B">
            <RichTextBox Name="ChatDisplay"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="Black"
                         FontSize="14"
                         Padding="15"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="ChatDisplay_TextChanged_1"/>
        </Border>

        <!-- 3. Input + Send button (bottom‑left) -->
        <Grid Grid.Row="2"
              Margin="30,0,30,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border
    CornerRadius="15"
    Background="#40483D8B"
    Padding="2">
                <TextBox Name="UserInput"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="Black"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         Padding="15,0"
                         KeyDown="UserInput_KeyDown">
                    <TextBox.Resources>
                        <Style TargetType="TextBox">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </Border>

            <Button Grid.Column="1"
                    Content="Send"
                    Width="80"
                    Margin="10,0,0,0"
                    Style="{StaticResource RoundedButtonStyle}"
                    Click="SendButton_Click"/>
        </Grid>

        <!-- 4. Action buttons (bottom‑right) -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,0,30,15">
            <Button Content="Quiz Game"
                    Width="100"
                    Margin="5,0"
                    Style="{StaticResource RoundedButtonStyle}"
                    Click="btnQuiz_Click"/>
            <Button Content="Tasks"
                    Width="100"
                    Margin="5,0"
                    Style="{StaticResource RoundedButtonStyle}"
                    Click="btnTasks_Click"/>
            <Button Content="Log"
                    Width="100"
                    Margin="5,0"
                    Style="{StaticResource RoundedButtonStyle}"
                    Click="btnLog_Click"/>
            <Button Content="Help"
                    Width="100"
                    Margin="5,0"
                    Style="{StaticResource RoundedButtonStyle}"
                    Click="btnHelp_Click"/>
        </StackPanel>
    </Grid>
</Window>

