<Window x:Class="CyberSecurityAwarenessChatBot.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSecurityAwarenessChatBot"
        mc:Ignorable="d"
        Title="Cybersecurity Quiz"
        Height="550" Width="800"
        MinHeight="400" MinWidth="600"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <!--Window resources are used for converting values and styling -->
    <Window.Resources>
        <!--Styling the buttons making it easy to use-->
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Lavender"/>
            <Setter Property="Foreground" Value="DarkSlateBlue"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#AAFFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!--Background image for more appealing look-->
        <Grid.Background>
            <ImageBrush ImageSource="/pexels-codioful-7134987.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Progress -->
            <RowDefinition Height="*"/>
            <!-- Question + Options -->
            <RowDefinition Height="Auto"/>
            <!-- Feedback -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Quiz Game"
                   FontSize="42"
                   FontWeight="Bold"
                   Foreground="DarkSlateBlue"
                   HorizontalAlignment="Center"
                   Margin="0,15,0,5"/>

        <!-- Progress & Score -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,10">
            <TextBlock Name="txtProgress"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="DarkSlateBlue"/>
            <TextBlock Text="   |   "
                       FontSize="16"
                       Foreground="DarkSlateBlue"/>
            <TextBlock Name="txtScore"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="DarkSlateBlue"/>
        </StackPanel>

        <!-- Question & Answer options -->
        <Border Grid.Row="1"
                CornerRadius="15"
                Margin="30,26,30,10" Grid.RowSpan="2">
            <Border.Background>
                <SolidColorBrush Color="DarkSlateBlue" Opacity="0.25"/>
            </Border.Background>
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="txtQuestion"
                           Grid.Row="0"
                           FontSize="20"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Foreground="White"
                           Margin="0,0,0,10"/>

                <StackPanel x:Name="spOptions"
                            Grid.Row="1"
                            Margin="0,5,0,0"/>
            </Grid>
        </Border>

        <!-- Feedback panel -->
        <Border Grid.Row="3"
                CornerRadius="15"
                Margin="30,0,30,15">
            <Border.Background>
                <SolidColorBrush Color="DarkSlateBlue" Opacity="0.30"/>
            </Border.Background>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Name="txtFeedback"
                           FontSize="16"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Foreground="White"
                           Margin="15"/>
            </ScrollViewer>
        </Border>

        <!-- Control buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,15">
            <Button Name="btnRestart"
                    Content="Restart"
                    Width="90"
                    Margin="5"
                    Style="{StaticResource RoundedButtonStyle}"
                    Click="BtnRestart_Click"/>
            <Button Name="btnClose"
                    Content="Exit"
                    Width="90"
                    Margin="5"
                    Style="{StaticResource RoundedButtonStyle}"
                    Click="BtnClose_Click"/>
            <Button Name="btnNext"
                    Content="Next"
                    Width="90"
                    Margin="5"
                    IsEnabled="False"
                    Style="{StaticResource RoundedButtonStyle}"
                    Click="BtnNext_Click"/>
        </StackPanel>
    </Grid>
</Window>
