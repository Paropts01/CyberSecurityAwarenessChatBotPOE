<!--
    QuizWindow.xaml

    This window provides an interactive Cybersecurity Quiz.

    Features:
    - Displays quiz questions
    - Shows multiple-choice answers
    - Tracks progress and score
    - Displays feedback
    - Allows quiz restart and exit
-->

<Window x:Class="CyberSecurityAwarenessChatBot.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSecurityAwarenessChatBot"
        mc:Ignorable="d"
        Title="Cybersecurity Quiz"
        Height="450"
        Width="800"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <!-- =========================================================
         RESOURCES
         ========================================================= -->
    <Window.Resources>

        <!-- Rounded Modern Button Style -->
        <Style x:Key="RoundedButtonStyle"
               TargetType="Button">

            <Setter Property="Background"
                    Value="Lavender"/>

            <Setter Property="Foreground"
                    Value="DarkSlateBlue"/>

            <Setter Property="FontWeight"
                    Value="Bold"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="Height"
                    Value="40"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- Hover Effect -->
            <Style.Triggers>

                <Trigger Property="IsMouseOver"
                         Value="True">

                    <Setter Property="Background"
                            Value="#AAFFFFFF"/>

                </Trigger>

            </Style.Triggers>

        </Style>

    </Window.Resources>

    <!-- =========================================================
         MAIN GRID
         ========================================================= -->
    <Grid>

        <!-- Background Image -->
        <Grid.Background>
            <ImageBrush ImageSource="/pexels-codioful-7134987.jpg"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <!-- Optional Overlay -->
        <Rectangle Fill="#20FFFFFF"/>

        <!-- =====================================================
             QUIZ TITLE
             ===================================================== -->
        <TextBlock Text="Quiz Game"
                   FontSize="52"
                   FontWeight="Bold"
                   Foreground="DarkSlateBlue"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,15,0,0"/>

        <!-- =====================================================
             PROGRESS DISPLAY
             ===================================================== -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,85,0,0">

            <TextBlock Name="txtProgress"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="DarkSlateBlue"/>

            <TextBlock Text="   |   "
                       Foreground="DarkSlateBlue"/>

            <TextBlock Name="txtScore"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="DarkSlateBlue"/>

        </StackPanel>

        <!-- =====================================================
             QUESTION PANEL
             ===================================================== -->
        <Border CornerRadius="15"
                Margin="50,120,140,150"
                BorderThickness="0">

            <Border.Background>
                <SolidColorBrush Color="DarkSlateBlue"
                                 Opacity="0.18"/>
            </Border.Background>

            <Border.Effect>
                <DropShadowEffect BlurRadius="15"
                                  ShadowDepth="2"
                                  Opacity="0.2"/>
            </Border.Effect>

            <StackPanel Margin="20">

                <!-- Question Text -->
                <TextBlock Name="txtQuestion"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,0,0,15"
                           Foreground="Black"/>

                <!-- Quiz Options -->
                <StackPanel Name="spOptions"/>

            </StackPanel>

        </Border>

        <!-- =====================================================
             FEEDBACK PANEL
             ===================================================== -->
        <Border CornerRadius="15"
                Margin="50,320,250,60"
                BorderThickness="0">

            <Border.Background>
                <SolidColorBrush Color="DarkSlateBlue"
                                 Opacity="0.18"/>
            </Border.Background>

            <Border.Effect>
                <DropShadowEffect BlurRadius="15"
                                  ShadowDepth="2"
                                  Opacity="0.2"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <TextBlock Name="txtFeedback"
                           Margin="15"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Foreground="Black"/>

            </ScrollViewer>

        </Border>

        <!-- =====================================================
             CONTROL BUTTONS
             ===================================================== -->

        <!-- Restart Quiz -->
        <Button Name="btnRestart"
                Content="Restart Quiz"
                Width="94"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,134,22,0"
                Style="{StaticResource RoundedButtonStyle}"
                Click="BtnRestart_Click"/>

        <!-- Exit Quiz -->
        <Button Name="btnClose"
                Content="Exit"
                Width="94"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,192,22,0"
                Style="{StaticResource RoundedButtonStyle}"
                Click="BtnClose_Click"/>

        <!-- Next Question -->
        <Button Name="btnNext"
                Content="Next Question"
                Width="102"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,128,72"
                IsEnabled="False"
                Style="{StaticResource RoundedButtonStyle}"
                Click="BtnNext_Click"/>

    </Grid>

</Window>
