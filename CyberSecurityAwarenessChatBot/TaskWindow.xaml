<!--
    TaskWindow.xaml

    Modern Task Assistant Window – cleaned‑up layout
    using a Grid with rows and columns for consistent spacing.
-->

<Window x:Class="CyberSecurityAwarenessChatBot.TaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSecurityAwarenessChatBot"
        mc:Ignorable="d"
        Title="Task Assistant"
        Height="550"
        Width="800"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <!-- Converters -->
        <local:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <local:OverdueConverter x:Key="OverdueConverter"/>

        <!-- Rounded Button Style (matches main window) -->
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Lavender"/>
            <Setter Property="Foreground" Value="DarkSlateBlue"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#AAFFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- =========================================================
         MAIN GRID – 3 rows, 1 column
         ========================================================= -->
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/pexels-codioful-7134987.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Input area -->
            <RowDefinition Height="*"/>
            <!-- Task list -->
            <RowDefinition Height="Auto"/>
            <!-- Action buttons -->
        </Grid.RowDefinitions>

        <!-- =====================================================
             TITLE
             ===================================================== -->
        <TextBlock Grid.Row="0"
                   Text="Task Assistant"
                   FontSize="42"
                   FontWeight="Bold"
                   Foreground="DarkSlateBlue"
                   HorizontalAlignment="Center"
                   Margin="0,15,0,10"/>

        <!-- =====================================================
             INPUT AREA
             ===================================================== -->
        <Border Grid.Row="1"
                CornerRadius="15"
                Margin="30,0,30,15"
                Padding="20,15">
            <Border.Background>
                <SolidColorBrush Color="DarkSlateBlue" Opacity="0.18"/>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Title"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="DarkSlateBlue"
                           VerticalAlignment="Center"
                           Margin="0,0,10,5"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Name="txtTaskTitle"
                         Height="30"
                         Margin="0,0,20,5"
                         VerticalContentAlignment="Center"
                         Padding="8,0"/>

                <!-- Description -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Description"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="DarkSlateBlue"
                           VerticalAlignment="Center"
                           Margin="0,0,10,5"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                         Name="txtTaskDescription"
                         Height="30"
                         Margin="0,0,20,5"
                         VerticalContentAlignment="Center"
                         Padding="8,0"/>

                <!-- Date -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Date"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="DarkSlateBlue"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <DatePicker Grid.Row="2" Grid.Column="1"
                            Name="dpReminder"
                            Height="30"
                            Margin="0,0,20,0"
                            SelectedDate="{x:Null}"/>

                <!-- Add & Clear Reminder Buttons -->
                <StackPanel Grid.Row="0" Grid.Column="2" Grid.RowSpan="3"
                            Orientation="Vertical"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <Button Name="btnAddTask"
                            Content="ADD"
                            Style="{StaticResource RoundedButtonStyle}"
                            Width="90"
                            Margin="0,0,0,8"
                            Click="btnAddTask_Click"/>
                    <Button Name="btnClearReminder"
                            Content="CLEAR DATE"
                            Style="{StaticResource RoundedButtonStyle}"
                            Width="90"
                            Click="btnClearReminder_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- =====================================================
             TASK LIST
             ===================================================== -->
        <Border Grid.Row="2"
                CornerRadius="15"
                Margin="30,0,30,10"
                Padding="0">
            <Border.Background>
                <SolidColorBrush Color="DarkSlateBlue" Opacity="0.18"/>
            </Border.Background>

            <ListBox Name="lstTasks"
                     SelectionChanged="LstTasks_SelectionChanged"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="10"
                     Foreground="White">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="6"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#25FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#40FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="10" Padding="8" Margin="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Status Icon -->
                                <TextBlock Grid.Column="0"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           Foreground="White"
                                           Text="{Binding IsCompleted, Converter={StaticResource BoolToStatusConverter}}"/>

                                <!-- Task Details -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Foreground="{Binding ReminderDate, Converter={StaticResource OverdueConverter}}"/>
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="12"
                                               Foreground="White"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Reminder Date -->
                                <TextBlock Grid.Column="2"
                                           FontSize="12"
                                           Foreground="White"
                                           VerticalAlignment="Center"
                                           Text="{Binding ReminderDate}"
                                           Visibility="{Binding ReminderDate, Converter={StaticResource NullToVisibilityConverter}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- =====================================================
             ACTION BUTTONS (Refresh, Complete, Delete)
             ===================================================== -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,15">
            <Button Name="btnRefresh"
                    Content="Refresh"
                    Style="{StaticResource RoundedButtonStyle}"
                    Width="100"
                    Margin="0,0,15,0"
                    Click="btnRefresh_Click"/>
            <Button Name="btnComplete"
                    Content="Complete"
                    Style="{StaticResource RoundedButtonStyle}"
                    Width="100"
                    Margin="0,0,15,0"
                    Click="btnComplete_Click"/>
            <Button Name="btnDelete"
                    Content="Delete"
                    Style="{StaticResource RoundedButtonStyle}"
                    Width="100"
                    Click="btnDelete_Click"/>
            <Button Name="btnBack"
        Content="Back"
        Style="{StaticResource RoundedButtonStyle}"
        Width="100"
        Margin="15,0,0,0"
        Click="btnBack_Click"/>
        </StackPanel>
    </Grid>
</Window>