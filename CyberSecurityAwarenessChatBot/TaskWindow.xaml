<!--
    TaskWindow.xaml

    Modern Task Assistant Window

    Features:
    • Add Tasks
    • Clear Reminder Date
    • Mark Tasks Complete
    • Delete Tasks
    • Refresh Tasks

    NOTE:
    All original control names and event handlers
    have been preserved for compatibility with
    the existing code-behind.
-->

<Window x:Class="CyberSecurityAwarenessChatBot.TaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSecurityAwarenessChatBot"
        mc:Ignorable="d"
        Title="Task Assistant"
        Height="500"
        Width="800"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <!-- =========================================================
         RESOURCES
         ========================================================= -->
    <Window.Resources>

        <!-- Declared Value Converters Linked to the C# Code -->
        <local:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <local:OverdueConverter x:Key="OverdueConverter"/>

        <!-- Rounded Modern Button Style -->
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Lavender"/>
            <Setter Property="Foreground" Value="DarkSlateBlue"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#AAFFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <!-- =========================================================
         MAIN GRID
         ========================================================= -->
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/pexels-codioful-7134987.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <TextBlock Text="Task Assistant" FontSize="52" FontWeight="Bold" Foreground="DarkSlateBlue" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0"/>

        <!-- TASK INPUT PANEL -->
        <Border CornerRadius="15" Margin="30,75,150,197">
            <Border.Background>
                <SolidColorBrush Color="DarkSlateBlue" Opacity="0.18"/>
            </Border.Background>

            <StackPanel Margin="30">
                <Grid Margin="0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Title" Grid.Column="0" FontSize="16" FontWeight="Bold" Foreground="DarkSlateBlue" Margin="0,-6,45,15"/>
                    <TextBox Name="txtTaskTitle" Height="30" Margin="10,-15,0,15" Grid.Column="1"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Description" Grid.Column="0" FontSize="16" FontWeight="Bold" Foreground="DarkSlateBlue" VerticalAlignment="Top" Margin="0,-17,0,0"/>
                    <TextBox Name="txtTaskDescription" Grid.Column="1" Height="30" Margin="10,-21,0,21"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="18.076"/>
                        <ColumnDefinition Width="81.924"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Date" Grid.Column="0" FontSize="16" FontWeight="Bold" Foreground="DarkSlateBlue" VerticalAlignment="Top" Margin="0,-15,0,0" Grid.ColumnSpan="2"/>
                    <DatePicker Name="dpReminder" SelectedDate="{x:Null}" Margin="8,-21,-8,-5" Grid.Column="2"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button Content="ADD" Name="btnAddTask" FontSize="16" Width="95" Margin="0,0,10,0" Style="{StaticResource RoundedButtonStyle}" Click="BtnAddTask_Click" Height="34"/>
                    <Button Content="CLEAR" FontSize="16" FontWeight="Bold" x:Name="btnClearReminder" Width="95" Style="{StaticResource RoundedButtonStyle}" Click="BtnClearReminder_Click" Height="34"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Text="Your Tasks" FontSize="18" FontWeight="Bold" Foreground="DarkSlateBlue" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="296,292,0,0"/>

        <!-- TASK LIST VIEW WITH VALUE CONVERTERS IMPLEMENTED -->
        <ListBox Name="lstTasks" Margin="30,320,30,20" SelectionChanged="LstTasks_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status Icon Converter -->
                        <TextBlock Text="{Binding IsCompleted, Converter={StaticResource BoolToStatusConverter}}" 
                                   Grid.Column="0" FontSize="16" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <!-- Overdue Color Brush Converter -->
                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold" 
                                       Foreground="{Binding ReminderDate, Converter={StaticResource OverdueConverter}}"/>
                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="Gray"/>
                        </StackPanel>

                        <!-- Date Visibility Converter -->
                        <TextBlock Text="{Binding ReminderDate}" Grid.Column="2" FontSize="12" VerticalAlignment="Center"
                                   Visibility="{Binding ReminderDate, Converter={StaticResource NullToVisibilityConverter}}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>